# Copy this file to `.env.local` for local development.
# Add the same variables in Vercel: Project Settings → Environment Variables

# Live site URL (required in Vercel Production — use your custom domain)
NEXT_PUBLIC_SITE_URL=https://abhishekshrivastav.co.in

# Optional — Google Search Console HTML tag verification value
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Profile / contact details
NEXT_PUBLIC_SITE_NAME=Abhishek Raj
NEXT_PUBLIC_CONTACT_EMAIL=abhishekr359@gmail.com
NEXT_PUBLIC_CONTACT_PHONE=+91-9262648753
NEXT_PUBLIC_CONTACT_LOCATION=Gurgaon & Noida, India
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/abhishekrajverma
NEXT_PUBLIC_GITHUB_URL=https://github.com/abhishekrajverma

# Optional — improves GitHub API rate limits for commit stats (read-only token)
GITHUB_TOKEN=

# Email (Nodemailer) — Gmail example below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=Your Name <your@gmail.com>

# Newsletter notify command secret
NEWSLETTER_NOTIFY_SECRET=

# Supabase (recommended backend for contact + newsletter storage)
# Create a project at https://supabase.com, then run:
#   supabase/migrations/001_portfolio_schema.sql
#   supabase/migrations/002_blog_storage_bucket.sql
# Upload blog posts: npm run blog:seed
# Upload profile photo: npm run profile:seed

# Blog Studio admin login (create user in Supabase Auth → Users)
ADMIN_EMAIL=abhishekr359@gmail.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional on Vercel for persistent subscribers (if not using Supabase)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
